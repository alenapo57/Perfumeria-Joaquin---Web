# =========================================================
# Copiar este archivo a .env.local y completar con los valores reales.
# .env.local NUNCA se sube a git (ya está en .gitignore por defecto
# de Next.js). En producción, estas mismas variables se cargan en
# el dashboard de Vercel (Settings > Environment Variables).
# =========================================================

# --- Supabase ---
# Se consiguen en: Supabase Dashboard > Project Settings > API

# Pública: se puede exponer en el navegador (por eso lleva NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ⚠️ SECRETA. Bypassea RLS por completo. JAMÁS agregarle el prefijo
# NEXT_PUBLIC_, o quedaría expuesta en el navegador. Solo se usa
# dentro de app/api/** (ver lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Mercado Pago ---
# Se consiguen en: https://www.mercadopago.com.ar/developers/panel/app
# Arrancar con las credenciales de TEST, recién antes de lanzar a
# producción se cambian por las de producción (ver Fase 6 del plan).

# ⚠️ SECRETA. Nunca con prefijo NEXT_PUBLIC_. Se usa para crear
# preferencias de pago y validar el webhook, siempre en el servidor.
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ⚠️ SECRETA. Usada para validar la firma (x-signature) del webhook.
# Se consigue en: Developers > Tu app > Webhooks > Clave secreta.
MERCADOPAGO_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Resend (emails transaccionales) ---
# Se consigue en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_NOTIFICATION_EMAIL=perfumeriajoaquin@gmail.com

# --- WhatsApp (no necesita API, solo el número) ---
NEXT_PUBLIC_WHATSAPP_NUMBER=5491173587226

# --- SEO / sitemap ---
# URL pública del sitio, usada para armar el sitemap.xml y las URLs
# absolutas de Open Graph. En local podés dejar localhost:3000; en
# Vercel se cambia por el dominio real (Fase 6).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
